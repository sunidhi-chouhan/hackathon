# Server-only — set in apps/web/.env.local for local dev, Vercel dashboard for production
GEMINI_API_KEY=your_gemini_api_key_here

# Optional server-wide default model override (used when no modelPreset is sent in API requests)
# GEMINI_MODEL=gemini-2.0-flash

# Optional client-safe branding
NEXT_PUBLIC_APP_NAME=CultureCompass AI
